{
  "$schema": "https://json.schemastore.org/web-manifest-combined.json",
  "name": "Web Components TASK",
  "short_name": "WCTASK",
  "description": "A TASK PWA built with standard Web Components and TypeScript.",
  "display": "standalone",
  "display_override": ["window-controls-overlay"],
  "orientation": "portrait-primary",
  "categories": ["productivity", "utilities"],
  "start_url": "/",
  "id": "/",
  "scope": "/",
  "background_color": "#0f172a",
  "theme_color": "#0f172a",
  "icons": [
    { "src": "/icons/icon.svg", "sizes": "144x144 192x192 512x512 640x640", "type": "image/svg+xml", "purpose": "any" },
    { "src": "/icons/icon-144.png", "sizes": "144x144", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-640.png", "sizes": "640x640", "type": "image/png", "purpose": "any" }
  ]
}
