{
  "extends": "@tsconfig/strictest/tsconfig.json",
  "compilerOptions": {
    "target": "ES2024",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "sourceMap": true,

    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "lib": [
      "DOM",
      "DOM.Iterable",
      "WebWorker"
    ],
    "outDir": "./dist",
    "paths": {
      "@app/*": ["./src/*"]
    }
  },
  "include": [
    "src"
  ]
}
